# OOD Agent configuration template.
# Copy this file to .env and replace placeholders with local values.
# Do not commit .env files or real credentials.

OOD_LLM_PROVIDER="your-llm-provider"
OOD_LLM_API_KEY="replace-with-api-key"
OOD_LLM_MODEL="your-model-name"
# Explicit privacy approval gate. Keep false unless ticket content is approved for Cloud LLM synthesis.
OOD_ALLOW_CLOUD_LLM=false

OOD_KNOWLEDGE_DIR="knowledge"
OOD_DATA_DIR="data"
OOD_STORAGE_DIR="data/storage"

OOD_VERBOSE=0
OOD_QUIET=false
